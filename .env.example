# Copy to .env and fill in. Variables prefixed PUBLIC_ are exposed to the browser.

# RAG chatbot backend (FastAPI on DigitalOcean). Leave blank to keep the
# ChatWidget in "coming soon" mock mode.
PUBLIC_CHAT_API_URL=

# Live gold/silver rate API (FastAPI /rates endpoint on DigitalOcean).
# Leave blank to hide the rate strip entirely — no placeholder numbers shown.
PUBLIC_RATES_API_URL=
