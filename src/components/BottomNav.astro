---
import Icon from './Icon.astro';
import { bottomNav, isActive } from '../config/nav';

const current = Astro.url.pathname;
const iconFor: Record<string, string> = {
  home: 'home',
  grid: 'grid',
  search: 'search',
  heart: 'heart',
  phone: 'phone',
};
---

<!-- Mobile-only thumb-zone navigation -->
<nav
  class="bottom-safe fixed inset-x-0 z-40 flex items-stretch border-t border-[var(--color-line)] bg-white/95 backdrop-blur md:hidden"
  aria-label="Primary"
>
  {bottomNav.map((item) => {
    const active = item.action !== 'search' && isActive(current, item.href);
    const cls = active ? 'text-[var(--color-gold)]' : 'text-[var(--color-muted)]';
    return item.action === 'search' ? (
      <button data-bottom-search class={`flex flex-1 flex-col items-center gap-0.5 py-2 ${cls}`} aria-label="Search">
        <Icon name={iconFor[item.icon]} size={22} />
        <span class="text-[11px]">{item.label}</span>
      </button>
    ) : (
      <a href={item.href} class={`flex flex-1 flex-col items-center gap-0.5 py-2 ${cls}`}>
        <Icon name={iconFor[item.icon]} size={22} />
        <span class="text-[11px]">{item.label}</span>
      </a>
    );
  })}
</nav>

<script>
  document
    .querySelector('[data-bottom-search]')
    ?.addEventListener('click', () => window.dispatchEvent(new Event('open-search')));
</script>
