---
// Lightweight inline SVG icons (lucide-style, stroke=currentColor).
// Replaces the heavy Material Symbols web font for better mobile performance.
interface Props {
  name: string;
  size?: number;
  class?: string;
  stroke?: number;
}
const { name, size = 24, class: cls = '', stroke = 1.75 } = Astro.props;

const paths: Record<string, string> = {
