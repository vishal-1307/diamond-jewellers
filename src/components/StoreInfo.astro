---
import Icon from './Icon.astro';
import { site } from '../config/site';
---
<div class="space-y-4">
  <div>
    <h3 class="font-[var(--font-heading)] text-lg">Phone / WhatsApp</h3>
    <a href={site.phoneTel} class="text-[var(--color-gold)]">{site.phoneDisplay}</a>
  </div>
  <div>
    <h3 class="font-[var(--font-heading)] text-lg">Email</h3>
    <a href={`mailto:${site.email}`} class="break-all text-[var(--color-gold)]">{site.email}</a>
  </div>
  <div>
    <h3 class="font-[var(--font-heading)] text-lg">Address</h3>
    <p class="text-[var(--color-muted)]">{site.address.line1}<br />{site.address.line2}</p>
  </div>
  <div>
    <h3 class="font-[var(--font-heading)] text-lg">Store Hours</h3>
    <p class="text-[var(--color-muted)]">{site.hours.display}</p>
    <p class="text-[var(--color-muted)]">{site.hours.sunday}</p>
  </div>
</div>
