---
import '../styles/global.css';
import SEO from '../components/SEO.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import BottomNav from '../components/BottomNav.astro';
import Banner from '../components/Banner.astro';
import Icon from '../components/Icon.astro';
import ChatWidget from '../components/islands/ChatWidget.tsx';
import { generalEnquiry } from '../lib/waLink';

interface Props {
  title: string;
  description: string;
  ogImage?: string;
  jsonLd?: Record<string, unknown> | Record<string, unknown>[];
}
const { title, description, ogImage, jsonLd } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    <meta name="theme-color" content="#b7860b" />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="apple-touch-icon" href="/icons/icon-192.png" />
    <link rel="manifest" href="/manifest.webmanifest" />
    <link rel="sitemap" href="/sitemap-index.xml" />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@600;700&family=Poppins:wght@400;500;600&display=swap"
      rel="stylesheet"
    />

    <SEO title={title} description={description} ogImage={ogImage} jsonLd={jsonLd} />
  </head>
  <body class="min-h-dvh">
    <Banner />
    <Header />

    <main class="pb-20 md:pb-0">
      <slot />
    </main>

    <Footer />
    <BottomNav />

    <!-- Floating actions -->
    <a
      href={generalEnquiry()}
      target="_blank"
      rel="noopener"
      aria-label="Chat on WhatsApp"
      class="bottom-safe fixed right-4 bottom-20 z-40 grid h-14 w-14 place-items-center rounded-full bg-[var(--color-whatsapp)] text-white shadow-lg md:bottom-6"
    >
      <Icon name="chat" size={28} />
    </a>
    <button
      id="back-to-top"
      aria-label="Back to top"
      class="bottom-safe fixed right-4 bottom-36 z-40 hidden h-11 w-11 place-items-center rounded-full bg-[var(--color-gold)] text-white shadow-lg md:bottom-24"
    >
      <Icon name="arrowUp" size={20} />
    </button>

    <ChatWidget client:idle />

    <script>
      import '../scripts/saved-ui.ts';

      // Back-to-top
      const btt = document.getElementById('back-to-top');
      if (btt) {
        const onScroll = () => {
          if (window.scrollY > 400) {
            btt.classList.remove('hidden');
            btt.classList.add('grid');
          } else {
            btt.classList.add('hidden');
            btt.classList.remove('grid');
          }
        };
        window.addEventListener('scroll', onScroll, { passive: true });
        btt.addEventListener('click', () => window.scrollTo({ top: 0, behavior: 'smooth' }));
      }

      // Register service worker (PWA)
      if ('serviceWorker' in navigator) {
        window.addEventListener('load', () => navigator.serviceWorker.register('/sw.js').catch(() => {}));
      }
    </script>
  </body>
</html>
