---
import '../styles/global.css';
import SEO from '../components/SEO.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import BottomNav from '../components/BottomNav.astro';
import Banner from '../components/Banner.astro';
import Icon from '../components/Icon.astro';
import ChatWidget from '../components/islands/ChatWidget.tsx';
import RateWidget from '../components/islands/RateWidget.tsx';
import { generalEnquiry } from '../lib/waLink';

interface Props {
  title: string;
  description: string;
  ogImage?: string;
  jsonLd?: Record<string, unknown> | Record<string, unknown>[];
}
const { title, description, ogImage, jsonLd } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    <meta name="theme-color" content="#b7860b" />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="apple-touch-icon" href="/icons/icon-192.png" />
    <link rel="manifest" href="/manifest.webmanifest" />
    <link rel="sitemap" href="/sitemap-index.xml" />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@600;700&family=Poppins:wght@400;500;600&display=swap"
      rel="stylesheet"
    />

    <SEO title={title} description={description} ogImage={ogImage} jsonLd={jsonLd} />
  </head>
  <body class="min-h-dvh">
    <Banner />
    <Header />
    <RateWidget client:visible />

    <main class="pb-20 md:pb-0">
      <slot />
    </main>

    <Footer />
    <BottomNav />

    <!-- Floating WhatsApp button — right side, clears bottom nav on mobile -->
    <a
      href={generalEnquiry()}
      target="_blank"
      rel="noopener"
      aria-label="Chat on WhatsApp"
      class="fixed right-4 z-40 grid h-14 w-14 place-items-center rounded-full bg-[var(--color-whatsapp)] text-white shadow-lg"
      style="bottom: calc(env(safe-area-inset-bottom, 0px) + 80px)"
    >
      <Icon name="chat" size={28} />
    </a>

    <!-- ChatWidget launcher sits on the left, same height -->
    <ChatWidget client:idle />

    <script>
      import '../scripts/saved-ui.ts';

      // Register service worker (PWA)
      if ('serviceWorker' in navigator) {
        window.addEventListener('load', () => navigator.serviceWorker.register('/sw.js').catch(() => {}));
      }
    </script>
  </body>
</html>
