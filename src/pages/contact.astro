---
import BaseLayout from '../layouts/BaseLayout.astro';
import StoreInfo from '../components/StoreInfo.astro';
import EnquiryForm from '../components/islands/EnquiryForm.tsx';
import { site } from '../config/site';

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'LocalBusiness',
  '@id': `${site.url}/#business`,
  name: site.name,
  url: site.url,
  telephone: site.phoneTel,
  email: site.email,
  address: {
    '@type': 'PostalAddress',
    streetAddress: site.address.line1,
    addressLocality: site.address.locality,
    addressRegion: site.address.region,
    postalCode: site.address.postalCode,
    addressCountry: site.address.country,
  },
  geo: { '@type': 'GeoCoordinates', latitude: site.address.lat, longitude: site.address.lng },
  openingHours: site.hours.schema,
  image: `${site.url}/og/default.jpg`,
};
---

<BaseLayout title="Contact Us" description="Visit Diamond Jewellers in Benipatti, Madhubani or message us on WhatsApp. Phone, address, store hours and location map." jsonLd={jsonLd}>
  <div class="container-dj section">
    <h1 class="section-title">Contact Us</h1>
    <p class="mx-auto mb-8 max-w-xl text-center text-[var(--color-muted)]">Questions? Visit us or send a message on WhatsApp — we reply quickly.</p>

    <div class="grid gap-8 md:grid-cols-2">
      <StoreInfo />

      <div class="rounded-xl border border-[var(--color-line)] bg-[var(--color-sand)] p-6">
        <h2 class="mb-5 text-center font-[var(--font-heading)] text-xl">Send us a message</h2>
        <EnquiryForm variant="contact" client:visible />
      </div>
    </div>

    <div class="mt-10 overflow-hidden rounded-xl border border-[var(--color-line)]">
      <iframe
        src={site.address.mapsEmbed}
        title="Diamond Jewellers location map"
        width="100%"
        height="360"
        style="border:0"
        loading="lazy"
        referrerpolicy="no-referrer-when-downgrade"
        allowfullscreen
      ></iframe>
    </div>
  </div>
</BaseLayout>
