---
import BaseLayout from '../layouts/BaseLayout.astro';
import { imgThumb, imgSrcset } from '../lib/img';
---

<BaseLayout title="About Us" description="Diamond Jewellers — a family-owned workshop crafting certified, ethically sourced jewellery since 2005 in Benipatti, Madhubani.">
  <div class="container-dj section">
    <h1 class="section-title">About Diamond Jewellers</h1>

    <div class="grid gap-8 md:grid-cols-[2fr_1fr]">
      <div>
        <p class="text-lg text-[var(--color-ink)]">
          Diamond Jewellers began as a family-owned workshop with a passion for timeless design and honest
          craftsmanship. Since 2005 we've created pieces that celebrate life's milestones — engagements,
          anniversaries, and everyday moments.
        </p>

        <h2 class="mt-8 font-[var(--font-heading)] text-[var(--text-h3)]">Our Values</h2>
        <ul class="mt-2 list-inside list-disc space-y-1 text-[var(--color-muted)]">
          <li>Certified, ethically sourced gemstones</li>
          <li>Handcrafted designs with meticulous attention to detail</li>
          <li>Transparent pricing and lasting trust</li>
        </ul>

        <h2 class="mt-8 font-[var(--font-heading)] text-[var(--text-h3)]">Our Workshop</h2>
        <p class="mt-2 text-[var(--color-muted)]">
          We work with skilled artisans and modern certification processes. Custom requests are handled
          end-to-end with fittings and design previews.
        </p>

        <div class="mt-5 grid grid-cols-2 gap-3">
          <img src={imgThumb('store-interior')} srcset={imgSrcset('store-interior')} sizes="(min-width:768px) 33vw, 50vw" alt="Inside the Diamond Jewellers showroom" width={800} height={800} loading="lazy" class="col-span-2 h-48 w-full rounded-xl object-cover" />
          <img src={imgThumb('crafting')} srcset={imgSrcset('crafting')} sizes="50vw" alt="A jeweller hand-crafting a piece" width={800} height={800} loading="lazy" class="h-44 w-full rounded-xl object-cover" />
          <img src={imgThumb('custom-filigree')} srcset={imgSrcset('custom-filigree')} sizes="50vw" alt="Custom diamond filigree design in progress" width={800} height={800} loading="lazy" class="h-44 w-full rounded-xl object-cover" />
        </div>
      </div>

      <aside class="h-fit rounded-xl border border-[var(--color-line)] bg-[var(--color-sand)] p-6 md:sticky md:top-24">
        <h2 class="font-[var(--font-heading)] text-xl">Visit Our Store</h2>
        <p class="mt-3 text-[var(--color-muted)]">In front of Hospital Road, Benipatti<br />Madhubani, Bihar 847223</p>
        <p class="mt-3 text-[var(--color-muted)]"><strong class="text-[var(--color-ink)]">Open:</strong> Mon–Sat, 10:00 AM – 8:00 PM</p>
        <a href="/contact" class="btn btn-primary mt-5 w-full">Get Directions</a>
      </aside>
    </div>
  </div>
</BaseLayout>
