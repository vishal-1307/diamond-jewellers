---
import BaseLayout from '../layouts/BaseLayout.astro';
import GalleryLightbox from '../components/islands/GalleryLightbox.tsx';
import type { GItem } from '../components/islands/GalleryLightbox.tsx';

const items: GItem[] = [
  { slug: 'custom-filigree', alt: 'Custom diamond filigree design' },
  { slug: 'diamond-rings', alt: 'Diamond rings collection' },
  { slug: 'gold-bangles', alt: 'Handcrafted gold bangles' },
  { slug: 'gold-bangles-stacked', alt: 'Polished gold bangles stacked' },
  { slug: 'gold-pendant', alt: 'Gold pendant close-up' },
  { slug: 'emerald-stud-earrings', alt: 'Emerald stud earrings' },
  { slug: 'bridal-set-tikka', alt: 'Bridal necklace set with maang tikka' },
  { slug: 'pearl-necklace-strand', alt: 'Single-strand pearl necklace' },
  { slug: 'model-jewellery', alt: 'Model wearing necklace, ring and bangles' },
];
---

<BaseLayout title="Gallery" description="A lookbook of Diamond Jewellers — product close-ups, bridal sets and custom designs. Tap any image to view full size.">
  <div class="container-dj section">
    <h1 class="section-title">Lookbook &amp; Gallery</h1>
    <p class="mx-auto mb-8 max-w-xl text-center text-[var(--color-muted)]">Product close-ups · Bridal sets · Custom designs</p>
    <GalleryLightbox items={items} client:visible />
  </div>
</BaseLayout>
