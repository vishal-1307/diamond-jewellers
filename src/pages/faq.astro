---
import BaseLayout from '../layouts/BaseLayout.astro';

const faqs = [
  { q: 'Are your gemstones certified?', a: 'Yes — all diamonds and precious stones come with a certificate. High-value stones include lab certification details.' },
  { q: 'What is your return / exchange policy?', a: 'Custom pieces are non-returnable. Standard items can be returned within 7 days in original condition (terms apply).' },
  { q: 'Do you offer resizing?', a: 'Yes — complimentary resizing within 15 days for selected items. Nominal charges may apply for others.' },
  { q: 'Do you deliver nationwide?', a: 'Local delivery is free, and we courier across India with insurance for high-value items.' },
  { q: 'Can I order a fully custom design?', a: 'Absolutely. Visit our Custom Orders page — share your idea and we craft it end-to-end with design previews.' },
];

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqs.map((f) => ({
    '@type': 'Question',
    name: f.q,
    acceptedAnswer: { '@type': 'Answer', text: f.a },
  })),
};
---

<BaseLayout title="FAQ" description="Frequently asked questions about Diamond Jewellers — certification, returns, resizing, delivery, and custom orders." jsonLd={jsonLd}>
  <div class="container-dj section max-w-3xl">
    <h1 class="section-title">Frequently Asked Questions</h1>

    <div class="space-y-3">
      {faqs.map((f) => (
        <details class="group rounded-xl border border-[var(--color-line)] bg-white p-5 [&_summary::-webkit-details-marker]:hidden">
          <summary class="flex cursor-pointer list-none items-center justify-between font-[var(--font-heading)] text-lg">
            {f.q}
            <span class="text-2xl font-light text-[var(--color-gold)] transition group-open:rotate-45">+</span>
          </summary>
          <p class="mt-3 leading-relaxed text-[var(--color-muted)]">{f.a}</p>
        </details>
      ))}
    </div>
  </div>
</BaseLayout>
