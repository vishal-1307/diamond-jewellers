---
import BaseLayout from '../layouts/BaseLayout.astro';
import EnquiryForm from '../components/islands/EnquiryForm.tsx';
import Icon from '../components/Icon.astro';
import { imgThumb, imgSrcset } from '../lib/img';
import { waLink } from '../lib/waLink';

const steps = [
  { n: '1', h: 'Consultation', p: 'Share your idea — a photo, sketch or description. We suggest options and estimate cost.' },
  { n: '2', h: 'Design & Approval', p: 'Receive design mockups. You approve before we begin crafting.' },
  { n: '3', h: 'Crafting & Delivery', p: 'Our artisans craft the piece, then final fitting and handover.' },
];
const examples = [
  { slug: 'diamond-stud-earrings', alt: 'Custom diamond stud earrings' },
  { slug: 'gold-pendant', alt: 'Custom gold pendant' },
  { slug: 'bridal-set-tikka', alt: 'Custom bridal necklace set' },
];
const directWa = waLink('Hi Diamond Jewellers, I am interested in a custom jewellery design. Please help me get started.');
---

<BaseLayout title="Custom Orders" description="Design your dream jewellery in three simple steps. Share your idea and our artisans bring it to life. Book a consultation on WhatsApp.">
  <div class="container-dj section">
    <h1 class="section-title">Design Your Dream Piece</h1>
    <p class="mx-auto mb-8 max-w-xl text-center text-[var(--color-muted)]">In three simple steps.</p>

    <div class="grid gap-4 md:grid-cols-3">
      {steps.map((s) => (
        <div class="rounded-xl border border-[var(--color-line)] bg-[var(--color-sand)] p-6">
          <div class="grid h-10 w-10 place-items-center rounded-full bg-[var(--color-gold)] font-[var(--font-heading)] text-lg text-white">{s.n}</div>
          <h2 class="mt-3 font-[var(--font-heading)] text-lg text-[var(--color-gold)]">{s.h}</h2>
          <p class="mt-1 text-sm text-[var(--color-muted)]">{s.p}</p>
        </div>
      ))}
    </div>

    <div class="mt-12 grid gap-8 md:grid-cols-2">
      <div>
        <h2 class="font-[var(--font-heading)] text-[var(--text-h3)]">Examples of Custom Work</h2>
        <div class="mt-3 grid grid-cols-3 gap-3">
          {examples.map((e) => (
            <img src={imgThumb(e.slug)} srcset={imgSrcset(e.slug)} sizes="33vw" alt={e.alt} width={400} height={400} loading="lazy" class="aspect-square rounded-lg object-cover" />
          ))}
        </div>
      </div>

      <div class="rounded-xl border border-[var(--color-line)] bg-[var(--color-sand)] p-6">
        <h2 class="mb-5 text-center font-[var(--font-heading)] text-xl">Book a Consultation</h2>
        <EnquiryForm variant="custom" client:visible />
        <a href={directWa} target="_blank" rel="noopener" class="btn btn-whatsapp mt-3 w-full">
          <Icon name="chat" size={18} /> Chat on WhatsApp Instead
        </a>
      </div>
    </div>
  </div>
</BaseLayout>
